# ============================================================
# Ayura OS — Universal Migration Framework
# Environment Configuration
# ============================================================
# This file works for ANY source system. Not all variables are
# required — it depends on which adapter you use.

# --- Source Database (for --source=sql adapter) ---
# Supports: MySQL, PostgreSQL, MSSQL
# Leave blank if using --source=file or --source=fhir
VAIDYO_DB_TYPE=postgres                # mysql | postgres
VAIDYO_DB_HOST=localhost
VAIDYO_DB_PORT=5432
VAIDYO_DB_NAME=legacy_hms
VAIDYO_DB_USER=migration_reader
VAIDYO_DB_PASSWORD=
VAIDYO_DB_SSL=false

# --- Target: Ayura OS (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=             # service_role key (bypasses RLS)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Migration Settings ---
MIGRATION_TENANT_ID=                   # UUID of the target hospital tenant
MIGRATION_BATCH_SIZE=1000
MIGRATION_DRY_RUN=true                 # Set to false for live writes
MIGRATION_STAGING_DIR=./staging
MIGRATION_ERRORS_DIR=./errors
MIGRATION_LOG_LEVEL=info               # debug | info | warn | error

# --- Optional: Attachment Migration ---
# Path to legacy system's uploaded files (X-rays, reports, etc.)
VAIDYO_ATTACHMENTS_PATH=/var/hospital/uploads
SUPABASE_STORAGE_BUCKET=clinical-documents
