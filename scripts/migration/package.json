{
  "name": "@project-nexus/migration",
  "version": "1.0.0",
  "private": true,
  "description": "Vaidyo → Ayura OS ETL migration pipeline",
  "type": "module",
  "scripts": {
    "templates": "tsx run.ts templates --output=./hospital-data",
    "discover": "tsx run.ts discover --source=sql",
    "migrate": "tsx run.ts",
    "migrate:dry": "tsx run.ts --dry-run",
    "migrate:file": "tsx run.ts --source=file",
    "migrate:sql": "tsx run.ts --source=sql",
    "migrate:fhir": "tsx run.ts --source=fhir",
    "verify": "tsx run.ts verify"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.5",
    "mysql2": "^3.9.0",
    "ora": "^8.0.1",
    "pg": "^8.11.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
}
