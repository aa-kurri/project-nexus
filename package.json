{
  "name": "project-nexus",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous engine: URL → PRD + Sprint Backlog + Production Code",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "crawl:test": "tsx scripts/test-crawl.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.7.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
