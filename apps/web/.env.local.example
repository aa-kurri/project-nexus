# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — required for Clinical Scribe (S-AI-SCRIBE-LIVE)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq — optional, enables real Whisper speech-to-text in Clinical Scribe
# Without this key the scribe uses a stub transcript for development
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Sarvam AI — OCR + multilingual translation for Document Intelligence module
# Enables /documents/upload (OCR), /documents/translate (22 Indian languages)
# Get your key at https://console.sarvam.ai
SARVAM_API_KEY=sk_...

# Sentry — error monitoring (S-INFRA-SENTRY)
# DSN: Sentry Dashboard → Project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Source-map upload — required only in CI (set in GitHub Actions secrets)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=ayura-web
SENTRY_AUTH_TOKEN=sntrys_...
# Release tag injected by CI (e.g. git SHA); optional in local dev
SENTRY_RELEASE=

# Razorpay — subscription billing (S-PAY-RAZORPAY)
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Webhook secret: Razorpay Dashboard → Webhooks → your endpoint → Secret
RAZORPAY_WEBHOOK_SECRET=...
