# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — required for Clinical Scribe (S-AI-SCRIBE-LIVE)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq — optional, enables real Whisper speech-to-text in Clinical Scribe
# Without this key the scribe uses a stub transcript for development
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Sarvam AI — OCR + multilingual translation for Document Intelligence module
# Enables /documents/upload (OCR), /documents/translate (22 Indian languages)
# Get your key at https://console.sarvam.ai
SARVAM_API_KEY=sk_...
